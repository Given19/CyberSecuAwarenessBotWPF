<Window x:Class="CyberSecuAwarenessBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard — Cybersecurity Awareness Chatbot"
        Height="780" Width="1100"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E6EDF3">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="90.63"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,1" Margin="0,0,0,605" Grid.RowSpan="2">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🛡" FontSize="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CyberGuard" FontSize="22" FontWeight="Bold"
                                   Foreground="#39D353" FontFamily="Consolas"/>
                        <TextBlock Text="Cybersecurity Awareness Chatbot"
                                   FontSize="11" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#39D353" Margin="0,0,6,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#39D353" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusLabel" Text="Online — Ready to assist"
                               Foreground="#8B949E" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnVoice" Content="🔊 Voice"
                            Style="{StaticResource CyberButtonSecondary}"
                            Margin="0,0,8,0"
                            Click="BtnVoice_Click"/>
                    <Button x:Name="BtnClear" Content="🗑 Clear"
                            Style="{StaticResource CyberButtonSecondary}"
                            Click="BtnClear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="0,0,1,0">
                <StackPanel Margin="16">
                    <Border Background="#0D1117" CornerRadius="8" Padding="10" Margin="0,0,0,16">
                        <TextBlock x:Name="AsciiArtBlock"
                                   FontFamily="Consolas" FontSize="8.5"
                                   Foreground="#39D353" TextWrapping="Wrap"
                                   LineHeight="12" TextAlignment="Center"/>
                    </Border>

                    <TextBlock Text="USER PROFILE" FontSize="10" FontWeight="Bold"
                               Foreground="#8B949E" Margin="0,0,0,8"/>
                    <Border Background="#21262D" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="👤 " FontSize="13"/>
                                <TextBlock x:Name="LblUserName" Text="Not set"
                                           Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭐ " FontSize="13"/>
                                <TextBlock x:Name="LblUserInterest" Text="No topic yet"
                                           Foreground="#8B949E" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="QUICK TOPICS" FontSize="10" FontWeight="Bold"
                               Foreground="#8B949E" Margin="0,0,0,8"/>
                    <StackPanel x:Name="QuickTopicsPanel"/>

                    <TextBlock Text="DETECTED MOOD" FontSize="10" FontWeight="Bold"
                               Foreground="#8B949E" Margin="0,16,0,8"/>
                    <Border Background="#21262D" CornerRadius="8" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="MoodEmoji" Text="😐" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock x:Name="MoodLabel" Text="Neutral"
                                       Foreground="#8B949E" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Chat area -->
            <Grid Grid.Column="1">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,16">
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- INPUT BAR -->
        <Border Grid.Row="1" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0" Margin="0,605,0,0" Grid.RowSpan="2" RenderTransformOrigin="0.504,0.032">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox"
                         Grid.Column="0"
                         Style="{StaticResource CyberTextBox}"
                         VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown"
                         TextChanged="InputBox_TextChanged" RenderTransformOrigin="0.495,1.048" Grid.ColumnSpan="2" Margin="0,10,98,28"/>

                <TextBlock x:Name="InputPlaceholder"
                           Grid.Column="0"
                           Text="Ask me about passwords, phishing, privacy, scams…"
                           Foreground="#484F58" FontSize="13"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <Button x:Name="BtnSend" Content="Send ➤"
                        Grid.Column="1"
                        Style="{StaticResource CyberButton}"
                        Margin="8,0,0,0"
                        Height="42" Width="90"
                        Click="BtnSend_Click"/>

                <Button x:Name="BtnHelp" Content="❓ Help"
                        Grid.Column="2"
                        Style="{StaticResource CyberButtonSecondary}"
                        Margin="6,0,0,0"
                        Height="42"
                        Click="BtnHelp_Click"/>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#0D1117"
                BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Padding="16,4" Margin="0,67,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar" Grid.Column="0"
                           Text="Welcome! Type a message to get started."
                           Foreground="#484F58" FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="CyberGuard v2.0 | PROG6221 Part 2"
                           Foreground="#484F58" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>